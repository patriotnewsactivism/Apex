# APEX Environment Configuration

# ─── OpenRouter (Required) ────────────────────────────────────────────────────
#
# OpenRouter gives you access to ALL major LLM providers through one API key:
# OpenAI, Anthropic, Google, Meta, Mistral, DeepSeek, and more.
#
# Get your key at: https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-your-key-here

# ─── Model Selection ──────────────────────────────────────────────────────────
#
# Override which model each agent tier uses. Uses OpenRouter's "provider/model" format.
# Browse all available models at: https://openrouter.ai/models
#
# Set a single model for ALL agents:
# APEX_MODEL=anthropic/claude-sonnet-4-5
#
# Or set per-role overrides (takes priority over APEX_MODEL):
# APEX_MODEL_CEO=anthropic/claude-opus-4-5
# APEX_MODEL_CTO=anthropic/claude-sonnet-4-5
# APEX_MODEL_COO=anthropic/claude-sonnet-4-5
# APEX_MODEL_LEAD_DEV=openai/gpt-4o
# APEX_MODEL_FRONTEND=openai/gpt-4o
# APEX_MODEL_BACKEND=openai/gpt-4o
# APEX_MODEL_DEVOPS=openai/gpt-4o
# APEX_MODEL_QA=openai/gpt-4o
# APEX_MODEL_RESEARCH=google/gemini-2.5-flash
# APEX_MODEL_DOCS=openai/gpt-4o-mini
# APEX_MODEL_OPS=openai/gpt-4o-mini
#
# Defaults (used if no override set):
#   CEO/CTO/COO    → anthropic/claude-sonnet-4-5
#   LEAD_DEV/Devs  → openai/gpt-4o
#   RESEARCH       → google/gemini-2.5-flash
#   DOCS/OPS       → openai/gpt-4o-mini

# ─── Agent Behavior ───────────────────────────────────────────────────────────

# on  = agents request human approval before write/shell actions (RECOMMENDED)
# off = fully autonomous — agents act without any confirmation
APEX_APPROVAL_MODE=on

# ─── Workspace ────────────────────────────────────────────────────────────────

# Directory agents can read and write files in.
# Defaults to the current working directory if not set.
# WORKSPACE_ROOT=C:\path\to\your\project

# ─── Database ─────────────────────────────────────────────────────────────────

# SQLite database file (auto-created on first run, stores agent memory + tasks)
DATABASE_PATH=.local/apex.db

# Set to 'true' to log all SQL queries to console
DB_LOGGING=false

# ─── Server ───────────────────────────────────────────────────────────────────

PORT=5000
